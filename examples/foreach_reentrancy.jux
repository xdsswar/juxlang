// for-each over a class's OWN collection field, while the loop body re-enters
// and mutates the same object. The iterable is read through the wrapper's
// `.0.borrow()`; iterating it directly would hold that guard across the body and
// any re-entrant `borrow_mut()` (even to a different field) would panic
// `RefCell already borrowed`. The iterable must be snapshotted first.
// Expected output: result size=3 / 10 / 20 / 30 / total=10.

public class Acc {
    public Vec<int> items;
    public Vec<int> result;
    public int total;
    public Acc() {
        this.items = new Vec<int>();
        this.result = new Vec<int>();
        this.total = 0;
    }
    public void seed() { this.items.push(1); this.items.push(2); this.items.push(3); }
    public void bump(int v) { this.total = this.total + v; }
    public void run() {
        // mutate a DIFFERENT field while iterating items
        for (var n : this.items) { this.result.push(n * 10); }
        print("result size=" + (int) this.result.len());
        for (var r : this.result) { print(r); }
        // re-entrant method call mutating the SAME object during iteration
        for (var n : this.items) { this.bump(n); }
        print("total=" + this.total);
    }
}

public void main() {
    var a = new Acc();
    var alias = a;   // force the shared-reference (wrapped) representation
    a.seed();
    a.run();
}
