// A minimal desktop window driven entirely from Jux, on the Rust `minifb`
// crate (declared as `rust.minifb` in jux.toml). Demonstrates the crate-interop
// chain end to end:
//
//   - `new WindowOptions()` — `WindowOptions` has no constructor; Jux gives a
//     no-ctor foreign type an implicit zero-arg constructor that lowers to
//     `WindowOptions::default()`.
//   - `new Window("…", w, h, opts)` — the Jux String is borrowed to the `&str`
//     parameter, and `Window::new`'s `Result` is unwrapped automatically (it
//     panics on failure, recoverable by a Jux try/catch).
//   - method calls (`is_open()`, `update()`) use the real Rust method names
//     verbatim — Jux surfaces foreign Rust members exactly as named (§G.4).

import rust.minifb.Window;
import rust.minifb.WindowOptions;

public void main() {
    var opts = new WindowOptions();
    var window = new Window("Jux on minifb", 480, 320, opts);

    // Pump the window until the user closes it.
    while (window.is_open()) {
        window.update();
    }
}
