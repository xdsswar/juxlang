// Auto-derived `operator string` per §O.3.1 — records get a Display
// impl from the backend so `$"$r"` and `print(r)` render the spec-exact
// `Name(field: value, …)` format.

public record Point(int x, int y) {}
public record User(String name, int age) {}

public void main() {
    var p = new Point(3, 4);
    var u = new User("alice", 30);
    print($"point=$p");
    print($"user=$u");
}
