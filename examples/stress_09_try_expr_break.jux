// Wave-3 borrow stress #9: a VALUE-producing lambda whose body is a
// try/catch over a captured wrapped collection, driven from a loop
// that breaks on the sentinel result. Expect 10 / 20 / done.
package stress09;

public class S9 {
    public Vec<int> items = new Vec<int>();
}

void main() {
    var s = new S9();
    s.items.push(10);
    s.items.push(20);
    var pop = () -> {
        try {
            if (s.items.is_empty()) {
                throw new RuntimeException("empty");
            }
            var v = s.items[0];
            s.items.remove(0);
            return v;
        } catch (RuntimeException e) {
            return -1;
        }
    };
    while (true) {
        var v = pop();
        if (v == -1) {
            break;
        }
        print(v);
    }
    print("done");
}
