<idea-plugin>
  <!-- Marketplace rule: the plugin ID must not contain the word "intellij"
       (verifyPlugin enforces it). Renamed from dev.jux.intellij before any
       public release, so no installed base is affected. -->
  <id>dev.jux.lang</id>
  <name>Jux Language</name>
  <vendor email="contact@xdsswar.dev" url="https://juxlang.dev/">
    XTREME SOFTWARE SOLUTIONS
  </vendor>

  <description><![CDATA[
    <h2>Jux Language</h2>

    <p><b>License &amp; disclaimer (please read before installing).</b>
      This plugin and the Jux toolchain are provided FREE OF CHARGE and
      <b>"AS IS", without warranty of any kind</b>. You use them entirely at your
      own risk; to the maximum extent permitted by law the authors and
      XTREME SOFTWARE SOLUTIONS accept <b>no liability</b> for any damages or data
      loss arising from their use. Jux is pre-release software and may change or
      contain defects. On first launch the plugin asks you to accept these terms.
      See <a href="https://juxlang.dev/">juxlang.dev</a> and
      <a href="https://github.com/xdsswar/juxlang">github.com/xdsswar/juxlang</a>.
    </p>
    <p>
      Full IDE support for <b>Jux</b> — a Java/C#-shaped language that lowers to
      Rust. Write familiar class/interface/enum/record syntax and ship native
      binaries through the Rust toolchain, with a first-class editing experience
      modelled on IntelliJ's own Java plugin.
    </p>

    <h3>Editing &amp; Navigation</h3>
    <ul>
      <li>Native, PSI-based parser (not just TextMate): a real syntax tree powers
        the <b>Structure View</b>, breadcrumbs, code folding, and brace matching</li>
      <li>Customizable <b>syntax highlighting</b> for keywords, types, strings,
        comments and annotations, with a dedicated color-settings page</li>
      <li><b>Go to Declaration</b>, <b>Find Usages</b>, and <b>Rename</b> for
        in-file declarations; cross-file and Rust-std symbols resolve through the
        language server</li>
      <li>Java-like editor behaviour: smart Enter, <b>Auto-Indent</b>
        (<code>Ctrl+Alt+I</code>), auto-closing quotes/brackets, and line/block
        comment toggling</li>
      <li><b>Optimize Imports</b> (<code>Ctrl+Alt+O</code>) — removes unused and
        duplicate imports and sorts the rest, just like Java</li>
    </ul>

    <h3>Code Generation (Alt+Insert)</h3>
    <ul>
      <li>Generate a <b>constructor</b>, <b>getters</b>, and <b>setters</b> from
        a class's fields</li>
      <li><b>Override / Implement Methods</b> — stubs for inherited methods not
        yet declared, walking the supertype chain</li>
    </ul>

    <h3>Intelligence (via <code>juxc-lsp</code>)</h3>
    <ul>
      <li>Live <b>diagnostics</b> with precise Jux error codes — workspace-aware,
        so cross-file and cross-package errors surface on the right file</li>
      <li><b>Completion</b> over keywords, project types, and receiver-aware
        members, with <b>auto-import</b> on accept and import quick-fixes</li>
      <li><b>Hover</b> showing inferred expression types and declaration
        signatures</li>
      <li>Autocomplete and auto-import over the <b>Rust standard library</b> and
        any bound Rust crate — rendered in Jux syntax — indexed automatically
        from your toolchain and project dependencies</li>
    </ul>

    <h3>Project &amp; Build</h3>
    <ul>
      <li><b>New → Jux Project</b>, <b>New → Jux File</b> (Class / Interface /
        Enum / Struct / Record / Annotation) and <b>New → Jux Package</b>, with
        <code>package</code> inferred from the source-root-relative path</li>
      <li><b>Jux tool window</b> (right side, like Gradle/Cargo): one-click
        Build, Run, Test, Build Release and Check over a live console</li>
      <li><b>Run configurations</b> that auto-detect any file with a
        <code>main</code> and wire up the gutter Run action</li>
      <li>IDE-wide <b>toolchain settings</b> (Settings | Tools | Jux Toolchain):
        auto-detects <code>juxc</code> / <code>jux</code> / <code>juxc-lsp</code>
        from <code>$JUX_HOME</code>, <code>PATH</code>, and common install
        locations</li>
    </ul>

    <p>
      Works in every IntelliJ-platform IDE (IDEA, CLion, RustRover, GoLand,
      PyCharm, …). Language-server features use the IDE's built-in LSP client
      where available (commercial IDEs and IDEA free mode 2025.2+); on
      Community editions, install the free
      <a href="https://plugins.jetbrains.com/plugin/23257-lsp4ij">LSP4IJ</a>
      plugin and the same features light up through it. When both clients are
      available the built-in one takes precedence automatically — only one
      <code>juxc-lsp</code> instance ever runs.
    </p>
  ]]></description>

  <!-- Platform-only dependency: the plugin loads in every IntelliJ-platform
       IDE (IDEA, CLion, GoLand, PyCharm, RustRover, …). -->
  <depends>com.intellij.modules.platform</depends>

  <!-- Native LSP client (diagnostics/hover/completion/auto-import from
       juxc-lsp). Gated on com.intellij.modules.lsp — first shipped in 2025.2
       (commercial IDEs AND unified IDEA free mode). On paid IDEs 2024.2–2025.1
       this module does NOT exist, so lsp.xml never loads there; the LSP4IJ
       fallback serves those builds instead (its nativeLspActive() checks for
       OUR registered provider, not mere EP existence, precisely so it steps
       up on those release lines). The lsp.xml extensions load only when the
       module exists, so the LSP classes are inert elsewhere (§I.6).
       LOCKSTEP: JuxLsp4ijServerFactory.nativeLspActive() mirrors this gate —
       change both together or two juxc-lsp servers will fight. -->
  <depends optional="true" config-file="lsp.xml">com.intellij.modules.lsp</depends>

  <!-- LSP4IJ fallback client: the same juxc-lsp features on IDEs WITHOUT the
       native LSP module (IDEA CE, PyCharm CE, Android Studio, older builds)
       when the free LSP4IJ plugin is installed. Loads only alongside LSP4IJ;
       on IDEs where lsp.xml also loaded, the factory disables itself so only
       one juxc-lsp runs (native wins). -->
  <depends optional="true" config-file="lsp4ij.xml">com.redhat.devtools.lsp4ij</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
        name="Jux File"
        implementationClass="dev.jux.intellij.JuxFileType"
        fieldName="INSTANCE"
        language="Jux"
        extensions="jux"/>
    <!-- Per-content file icons: a `.jux` file shows its primary type's glyph
         (class / interface / enum / record / struct / annotation) instead of
         the uniform file-type icon. -->
    <iconProvider implementation="dev.jux.intellij.JuxIconProvider" order="first"/>

    <!-- Internal templates backing the New → Jux File kinds (§I.5). The
         registered name must match the `.ft` filename stem. -->
    <internalFileTemplate name="Jux File"/>
    <internalFileTemplate name="Jux Class"/>
    <internalFileTemplate name="Jux Interface"/>
    <internalFileTemplate name="Jux Enum"/>
    <internalFileTemplate name="Jux Struct"/>
    <internalFileTemplate name="Jux Record"/>
    <internalFileTemplate name="Jux Annotation"/>

    <!-- PSI: lexer + recursive-descent parser building a real syntax tree
         (declaration-level today, full grammar in progress). Unlocks Structure
         View, folding, navigation, and PSI-based inspections. -->
    <lang.parserDefinition
        language="Jux"
        implementationClass="dev.jux.intellij.psi.JuxParserDefinition"/>

    <!-- PSI-driven editor features: outline (Structure View / Ctrl+F12) and
         code folding of bodies and comments. -->
    <lang.psiStructureViewFactory
        language="Jux"
        implementationClass="dev.jux.intellij.structure.JuxStructureViewFactory"/>
    <lang.foldingBuilder
        language="Jux"
        implementationClass="dev.jux.intellij.folding.JuxFoldingBuilder"/>

    <!-- PSI semantic highlighting: declaration names, reference uses
         (call sites, params, locals, type parameters, enum constants),
         primitive type names, and annotation names. -->
    <annotator
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxAnnotator"/>
    <!-- String interiors: escape sequences (valid vs malformed) and
         `${…}` interpolation holes, re-lexed so embedded expressions
         highlight like real code. -->
    <annotator
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxStringAnnotator"/>
    <!-- Always-on semantic diagnostics: runs juxc in check mode (JSON output,
         no codegen) off the EDT and paints real compiler errors/warnings
         inline. Stands down when juxc-lsp is serving (it publishes its own) or
         no toolchain is found. -->
    <externalAnnotator
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxSemanticAnnotator"/>

    <!-- IDE-side resolution: in-file Go-to-Declaration, Find Usages, and
         Rename for Jux declarations. Cross-file / std symbols defer to juxc-lsp. -->
    <psi.referenceContributor
        language="Jux"
        implementation="dev.jux.intellij.resolve.JuxReferenceContributor"/>
    <lang.findUsagesProvider
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxFindUsagesProvider"/>
    <lang.namesValidator
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxNamesValidator"/>
    <!-- Rename: in-file usages follow automatically (they resolve through the
         reference contributor); this adds same-scope name-collision conflicts. -->
    <renamePsiElementProcessor
        implementation="dev.jux.intellij.resolve.JuxRenamePsiElementProcessor"/>
    <completion.contributor
        language="Jux"
        implementationClass="dev.jux.intellij.completion.JuxCompletionContributor"/>

    <!-- Go-to-Class (Ctrl+N) / Go-to-Symbol (Ctrl+Alt+Shift+N) over the
         project's Jux declarations (backed by JuxTypeIndex's PSI walk). -->
    <gotoClassContributor
        implementation="dev.jux.intellij.resolve.JuxGotoClassContributor"/>
    <gotoSymbolContributor
        implementation="dev.jux.intellij.resolve.JuxGotoSymbolContributor"/>

    <!-- Gutter icons: ▶ on a runnable `main`, and ↑ overrides/implements
         arrows on methods that redeclare a supertype method. -->
    <runLineMarkerContributor
        language="Jux"
        implementationClass="dev.jux.intellij.run.JuxRunLineMarkerContributor"/>
    <codeInsight.lineMarkerProvider
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxLineMarkerProvider"/>
    <!-- Reverse (down-arrow) markers: is-subclassed-by / is-implemented-by /
         is-overridden-in, with a popup of the subtypes. Project-wide slow pass. -->
    <codeInsight.lineMarkerProvider
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxSubtypeLineMarkerProvider"/>
    <!-- Go To Implementation(s) (Ctrl+Alt+B): class -> subclasses,
         method -> overriding methods. Self-guards on Jux elements. -->
    <definitionsSearch
        implementation="dev.jux.intellij.resolve.JuxImplementationSearch"/>
    <!-- sec. P.7.8: observed / bound / plain gutter trio on properties. -->
    <codeInsight.lineMarkerProvider
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxPropertyLineMarkerProvider"/>

    <!-- Quick Documentation (Ctrl+Q) / nav-bar tooltip: render a declaration's
         signature + its doc comment from the PSI. Works without the LSP. -->
    <lang.documentationProvider
        language="Jux"
        implementationClass="dev.jux.intellij.documentation.JuxDocumentationProvider"/>

    <!-- Java-style inline parameter-name hints inside resolved calls
         (`foo(name: a, …)`). By-name over file-local declarations; ambiguous
         overloads get no hint so a label is never wrong. -->
    <codeInsight.parameterNameHints
        language="Jux"
        implementationClass="dev.jux.intellij.hints.JuxInlayHintsProvider"/>

    <!-- Live templates (psvm, sout, fore, ifn, tryc, cls, …) — the Java-IDE
         abbreviation-expand-on-Tab experience. The context type gates them to
         Jux code (not comments/strings); the set ships in liveTemplates/Jux.xml. -->
    <liveTemplateContext
        contextId="JUX"
        implementation="dev.jux.intellij.templates.JuxTemplateContextType"/>
    <defaultLiveTemplates file="liveTemplates/Jux"/>

    <!-- Native syntax highlighting + a customizable color page (§I.3). -->
    <lang.syntaxHighlighterFactory
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxSyntaxHighlighterFactory"/>
    <colorSettingsPage
        implementation="dev.jux.intellij.highlight.JuxColorSettingsPage"/>
    <!-- The dark-blue type-parameter color is hardcoded as the JUX_TYPE_PARAMETER
         key's default (JuxSyntaxHighlighter), so it applies on EVERY scheme —
         including custom themes — not just named ones. No per-scheme files. -->

    <!-- Editor behaviour: auto-close quotes, match/auto-close brackets, and
         Java-like Enter/auto-indent. -->
    <lang.quoteHandler
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxQuoteHandler"/>
    <lang.braceMatcher
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxBraceMatcher"/>
    <lang.commenter
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxCommenter"/>
    <enterHandlerDelegate
        implementation="dev.jux.intellij.editor.JuxEnterHandler"/>
    <lineIndentProvider
        implementation="dev.jux.intellij.editor.JuxLineIndentProvider"/>
    <!-- Smart typing for interpolation strings: `$"` auto-closes the quote and
         `${` auto-closes the hole (the lexer-driven quote/brace handlers can't,
         since `$` alone isn't yet a string token). -->
    <typedHandler
        implementation="dev.jux.intellij.editor.JuxTypedHandler"
        id="juxInterpString"/>

    <!-- Optimize Imports (Ctrl+Alt+O): drop unused / duplicate imports and sort
         the survivors, Java-style. The keybinding is the platform default. -->
    <lang.importOptimizer
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxImportOptimizer"/>

    <!-- Reformat Code (Ctrl+Alt+L): block-model formatter (indent + spacing,
         preserve-line-breaks v1) and the Code Style | Jux settings page. -->
    <lang.formatter
        language="Jux"
        implementationClass="dev.jux.intellij.format.JuxFormattingModelBuilder"/>
    <langCodeStyleSettingsProvider
        implementation="dev.jux.intellij.format.JuxLanguageCodeStyleSettingsProvider"/>

    <!-- Alt+Enter intentions. -->
    <intentionAction>
        <language>Jux</language>
        <className>dev.jux.intellij.intentions.JuxImportTypeIntention</className>
        <category>Jux</category>
    </intentionAction>

    <!-- Native inspections (IDE-side, no LSP needed) with quick-fixes. -->
    <localInspection
        language="Jux"
        shortName="JuxUnreachableCode"
        displayName="Unreachable code"
        groupName="Jux"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxUnreachableCodeInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxRedundantSemicolon"
        displayName="Redundant semicolon"
        groupName="Jux"
        enabledByDefault="true"
        level="WEAK WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxRedundantSemicolonInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxUnusedImport"
        displayName="Unused or duplicate import"
        groupName="Jux"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxUnusedImportInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxUnusedLocalSymbol"
        displayName="Unused local variable, parameter, or private field"
        groupName="Jux"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxUnusedLocalSymbolInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxUnresolvedReference"
        displayName="Unresolved reference"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxUnresolvedReferenceInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxMissingOverride"
        displayName="Missing @override annotation"
        groupName="Jux"
        enabledByDefault="true"
        level="WEAK WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxMissingOverrideInspection"/>
    <!-- Observable-property inspections (sec. P.7) — IDE-side; E0973/E0974
         have no compiler backstop yet, so each is individually disableable. -->
    <localInspection
        language="Jux"
        shortName="JuxPropertyNaming"
        displayName="Property name is not PascalCase (W0974)"
        groupName="Jux"
        enabledByDefault="true"
        level="WEAK WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxPropertyNamingInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxSetterEarlyReturn"
        displayName="Early return in property setter may skip observer fire (W0973)"
        groupName="Jux"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxSetterEarlyReturnInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxAccessorVisibility"
        displayName="Setter more visible than getter (E0972)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxAccessorVisibilityInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxPropertyNeverObserved"
        displayName="Property is never observed or bound (W0971)"
        groupName="Jux"
        enabledByDefault="true"
        level="WEAK WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxPropertyNeverObservedInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxBoundPropertyAssignment"
        displayName="Direct assignment to a bound property (E0973)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxBoundPropertyAssignmentInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxBindTypeMismatch"
        displayName="Binding between mismatched property types (E0974)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxBindTypeMismatchInspection"/>
    <!-- Testing-framework (sec. TS) and inheritance-shape inspections. -->
    <localInspection
        language="Jux"
        shortName="JuxTestAnnotationPlacement"
        displayName="Misplaced @Test/@BeforeEach/... annotation (TS.1)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxTestAnnotationPlacementInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxAbstractNotImplemented"
        displayName="Class doesn't implement inherited abstract methods (E0429)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxAbstractNotImplementedInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxExtendsClause"
        displayName="Invalid extends clause (E0420/E0422/E0423)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxExtendsClauseInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxImplementsClause"
        displayName="Implements a non-interface (E0424)"
        groupName="Jux"
        enabledByDefault="true"
        level="ERROR"
        implementationClass="dev.jux.intellij.inspections.JuxImplementsClauseInspection"/>
    <localInspection
        language="Jux"
        shortName="JuxInheritedTypeParam"
        displayName="Inherited type parameter used instead of its bound type"
        groupName="Jux"
        enabledByDefault="true"
        level="WARNING"
        implementationClass="dev.jux.intellij.inspections.JuxInheritedTypeParamInspection"/>

    <!-- Java-style Implement Methods (Ctrl+I) / Override Methods (Ctrl+O),
         backed by the same engine as Alt+Insert -> Override/Implement. These
         EPs feed the platform's ImplementMethods/OverrideMethods actions
         (CodeInsightActions.IMPLEMENT_METHOD / OVERRIDE_METHOD). -->
    <codeInsight.implementMethod
        language="Jux"
        implementationClass="dev.jux.intellij.codeInsight.JuxImplementMembersHandler"/>
    <codeInsight.overrideMethod
        language="Jux"
        implementationClass="dev.jux.intellij.codeInsight.JuxOverrideMembersHandler"/>

    <!-- New Project / New Module support: the "Jux" generator scaffolds a
         jux.toml + src/main.jux project (§I — project model). -->
    <moduleType
        id="JUX_MODULE_TYPE"
        implementationClass="dev.jux.intellij.project.JuxModuleType"/>

    <!-- Run support: a "Jux" run-configuration type plus a context producer
         that autodetects `main` and enables the toolbar/right-click Run. -->
    <configurationType
        implementation="dev.jux.intellij.run.JuxRunConfigurationType"/>
    <runConfigurationProducer
        implementation="dev.jux.intellij.run.JuxRunConfigurationProducer"/>
    <!-- Test-mode producer: @Test functions / test files / directories run
         `jux test <pattern>` with the SM test-tree console (sec. TS). -->
    <runConfigurationProducer
        implementation="dev.jux.intellij.run.JuxTestRunConfigurationProducer"/>

    <!-- Build/run CONSOLE — anchored at the BOTTOM, next to Terminal / Build /
         Run: one-click Build / Run / Test / Build Release / Check over a live
         console. -->
    <toolWindow id="Jux Build"
                anchor="bottom"
                factoryClass="dev.jux.intellij.toolwindow.JuxToolWindowFactory"
                icon="dev.jux.intellij.JuxIcons.TOOL_WINDOW"/>
    <!-- Project structure — anchored RIGHT, like Cargo / Gradle: a tree of the
         project's modules (from jux.toml), their versions, dependencies, and
         source roots. -->
    <toolWindow id="Jux Project"
                anchor="right"
                factoryClass="dev.jux.intellij.toolwindow.JuxProjectToolWindowFactory"
                icon="dev.jux.intellij.JuxIcons.TOOL_WINDOW"/>

    <!-- Persisted, IDE-wide Jux toolchain configuration (juxc / juxc-lsp / jux).
         Auto-detected from $JUX_HOME / PATH / install locations; configurable in
         Settings | Tools | Jux Toolchain. Every feature (LSP, Run, tool window)
         resolves through it. -->
    <applicationService serviceImplementation="dev.jux.intellij.settings.JuxSettings"/>
    <applicationConfigurable parentId="tools"
                             id="dev.jux.intellij.settings.JuxConfigurable"
                             instance="dev.jux.intellij.settings.JuxConfigurable"
                             displayName="Jux Toolchain"/>

    <!-- One-time "AS IS / no liability" agreement, shown on first project open
         until accepted (application-wide, see JuxLicense). -->
    <postStartupActivity implementation="dev.jux.intellij.license.JuxLicenseStartup"/>
    <!-- Auto-create a Run config for each binary module's main entry point
         (from jux.toml [[bin]] / src/main.jux), so "Run" is always available. -->
    <postStartupActivity implementation="dev.jux.intellij.run.JuxRunConfigStartup"/>
  </extensions>

  <actions>
    <!-- A single "Jux File" entry under New, anchored before the generic
         "New File". Its dialog offers the class/interface/enum/record/
         annotation kinds, each with an icon — the Kotlin-plugin idiom. -->
    <action id="Jux.NewFile"
            class="dev.jux.intellij.actions.NewJuxFileAction"
            text="Jux File"
            description="Create a new Jux file">
      <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
    </action>
    <!-- New → Jux Package (nested directories from a dotted name). -->
    <action id="Jux.NewPackage"
            class="dev.jux.intellij.actions.NewJuxPackageAction"
            text="Jux Package"
            description="Create a new Jux package (nested directories)">
      <add-to-group group-id="NewGroup" anchor="after" relative-to-action="Jux.NewFile"/>
    </action>

    <!-- Alt+Insert "Generate" menu inside a Jux class: constructor + accessors
         built from the class's own fields. Each is only enabled inside a type
         body (see JuxGenerateAction.update). -->
    <action id="Jux.Generate.Constructor"
            class="dev.jux.intellij.actions.JuxGenerateConstructorAction"
            text="Constructor"
            description="Generate a constructor from the class's fields">
      <add-to-group group-id="GenerateGroup" anchor="first"/>
    </action>
    <action id="Jux.Generate.Getters"
            class="dev.jux.intellij.actions.JuxGenerateGettersAction"
            text="Getters"
            description="Generate a getter for each field">
      <add-to-group group-id="GenerateGroup" anchor="after" relative-to-action="Jux.Generate.Constructor"/>
    </action>
    <action id="Jux.Generate.Setters"
            class="dev.jux.intellij.actions.JuxGenerateSettersAction"
            text="Setters"
            description="Generate a setter for each field">
      <add-to-group group-id="GenerateGroup" anchor="after" relative-to-action="Jux.Generate.Getters"/>
    </action>
    <action id="Jux.Generate.OverrideMethods"
            class="dev.jux.intellij.actions.JuxOverrideMethodsAction"
            text="Override/Implement Methods"
            description="Generate @override stubs for inherited methods not yet declared">
      <add-to-group group-id="GenerateGroup" anchor="after" relative-to-action="Jux.Generate.Setters"/>
    </action>
    <action id="Jux.ShowLicense"
            class="dev.jux.intellij.license.JuxShowLicenseAction"
            text="Jux License &amp; Disclaimer..."
            description="Show the Jux plugin license and AS-IS disclaimer">
      <add-to-group group-id="HelpMenu" anchor="last"/>
    </action>
  </actions>
</idea-plugin>
