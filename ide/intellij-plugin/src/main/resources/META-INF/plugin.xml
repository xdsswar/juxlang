<idea-plugin>
  <id>dev.jux.intellij</id>
  <name>Jux Language</name>
  <vendor email="contact@xdsswar.dev" url="https://github.com/xdsswar/juxlang">
    XTREME SOFTWARE SOLUTIONS
  </vendor>

  <description><![CDATA[
    <h2>Jux Language</h2>
    <p>
      Full IDE support for <b>Jux</b> — a Java/C#-shaped language that lowers to
      Rust. Write familiar class/interface/enum/record syntax and ship native
      binaries through the Rust toolchain, with a first-class editing experience
      modelled on IntelliJ's own Java plugin.
    </p>

    <h3>Editing &amp; Navigation</h3>
    <ul>
      <li>Native, PSI-based parser (not just TextMate): a real syntax tree powers
        the <b>Structure View</b>, breadcrumbs, code folding, and brace matching</li>
      <li>Customizable <b>syntax highlighting</b> for keywords, types, strings,
        comments and annotations, with a dedicated color-settings page</li>
      <li><b>Go to Declaration</b>, <b>Find Usages</b>, and <b>Rename</b> for
        in-file declarations; cross-file and Rust-std symbols resolve through the
        language server</li>
      <li>Java-like editor behaviour: smart Enter, <b>Auto-Indent</b>
        (<code>Ctrl+Alt+I</code>), auto-closing quotes/brackets, and line/block
        comment toggling</li>
      <li><b>Optimize Imports</b> (<code>Ctrl+Alt+O</code>) — removes unused and
        duplicate imports and sorts the rest, just like Java</li>
    </ul>

    <h3>Code Generation (Alt+Insert)</h3>
    <ul>
      <li>Generate a <b>constructor</b>, <b>getters</b>, and <b>setters</b> from
        a class's fields</li>
      <li><b>Override / Implement Methods</b> — stubs for inherited methods not
        yet declared, walking the supertype chain</li>
    </ul>

    <h3>Intelligence (via <code>juxc-lsp</code>)</h3>
    <ul>
      <li>Live <b>diagnostics</b> with precise Jux error codes — workspace-aware,
        so cross-file and cross-package errors surface on the right file</li>
      <li><b>Completion</b> over keywords, project types, and receiver-aware
        members, with <b>auto-import</b> on accept and import quick-fixes</li>
      <li><b>Hover</b> showing inferred expression types and declaration
        signatures</li>
      <li>Autocomplete and auto-import over the <b>Rust standard library</b> and
        any bound Rust crate — rendered in Jux syntax — indexed automatically
        from your toolchain and project dependencies</li>
    </ul>

    <h3>Project &amp; Build</h3>
    <ul>
      <li><b>New → Jux Project</b>, <b>New → Jux File</b> (Class / Interface /
        Enum / Struct / Record / Annotation) and <b>New → Jux Package</b>, with
        <code>package</code> inferred from the source-root-relative path</li>
      <li><b>Jux tool window</b> (right side, like Gradle/Cargo): one-click
        Build, Run, Test, Build Release and Check over a live console</li>
      <li><b>Run configurations</b> that auto-detect any file with a
        <code>main</code> and wire up the gutter Run action</li>
      <li>IDE-wide <b>toolchain settings</b> (Settings | Tools | Jux Toolchain):
        auto-detects <code>juxc</code> / <code>jux</code> / <code>juxc-lsp</code>
        from <code>$JUX_HOME</code>, <code>PATH</code>, and common install
        locations</li>
    </ul>

    <p>
      Works in every IntelliJ-platform IDE (IDEA, CLion, RustRover, GoLand,
      PyCharm, …). The language-server features require an Ultimate-class IDE or
      the LSP4IJ plugin on Community editions.
    </p>
  ]]></description>

  <!-- Platform-only dependency: the plugin loads in every IntelliJ-platform
       IDE (IDEA, CLion, GoLand, PyCharm, RustRover, …). -->
  <depends>com.intellij.modules.platform</depends>

  <!-- Native LSP client (diagnostics/hover/completion/auto-import from
       juxc-lsp). The lsp.xml extensions load only when the Ultimate module is
       present, so the LSP classes are inert on Community-only IDEs (§I.6). -->
  <depends optional="true" config-file="lsp.xml">com.intellij.modules.ultimate</depends>

  <extensions defaultExtensionNs="com.intellij">
    <fileType
        name="Jux File"
        implementationClass="dev.jux.intellij.JuxFileType"
        fieldName="INSTANCE"
        language="Jux"
        extensions="jux"/>

    <!-- Internal templates backing the New → Jux File kinds (§I.5). The
         registered name must match the `.ft` filename stem. -->
    <internalFileTemplate name="Jux File"/>
    <internalFileTemplate name="Jux Class"/>
    <internalFileTemplate name="Jux Interface"/>
    <internalFileTemplate name="Jux Enum"/>
    <internalFileTemplate name="Jux Struct"/>
    <internalFileTemplate name="Jux Record"/>
    <internalFileTemplate name="Jux Annotation"/>

    <!-- PSI: lexer + recursive-descent parser building a real syntax tree
         (declaration-level today, full grammar in progress). Unlocks Structure
         View, folding, navigation, and PSI-based inspections. -->
    <lang.parserDefinition
        language="Jux"
        implementationClass="dev.jux.intellij.psi.JuxParserDefinition"/>

    <!-- PSI-driven editor features: outline (Structure View / Ctrl+F12) and
         code folding of bodies and comments. -->
    <lang.psiStructureViewFactory
        language="Jux"
        implementationClass="dev.jux.intellij.structure.JuxStructureViewFactory"/>
    <lang.foldingBuilder
        language="Jux"
        implementationClass="dev.jux.intellij.folding.JuxFoldingBuilder"/>

    <!-- PSI semantic highlighting: primitive type names, annotation names,
         declaration names (decl-vs-reference colouring lands with Phase 5). -->
    <annotator
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxAnnotator"/>

    <!-- IDE-side resolution: in-file Go-to-Declaration, Find Usages, and
         Rename for Jux declarations. Cross-file / std symbols defer to juxc-lsp. -->
    <psi.referenceContributor
        language="Jux"
        implementation="dev.jux.intellij.resolve.JuxReferenceContributor"/>
    <lang.findUsagesProvider
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxFindUsagesProvider"/>
    <lang.namesValidator
        language="Jux"
        implementationClass="dev.jux.intellij.resolve.JuxNamesValidator"/>
    <completion.contributor
        language="Jux"
        implementationClass="dev.jux.intellij.completion.JuxCompletionContributor"/>

    <!-- Quick Documentation (Ctrl+Q) / nav-bar tooltip: render a declaration's
         signature + its doc comment from the PSI. Works without the LSP. -->
    <lang.documentationProvider
        language="Jux"
        implementationClass="dev.jux.intellij.documentation.JuxDocumentationProvider"/>

    <!-- Native syntax highlighting + a customizable color page (§I.3). -->
    <lang.syntaxHighlighterFactory
        language="Jux"
        implementationClass="dev.jux.intellij.highlight.JuxSyntaxHighlighterFactory"/>
    <colorSettingsPage
        implementation="dev.jux.intellij.highlight.JuxColorSettingsPage"/>

    <!-- Editor behaviour: auto-close quotes, match/auto-close brackets, and
         Java-like Enter/auto-indent. -->
    <lang.quoteHandler
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxQuoteHandler"/>
    <lang.braceMatcher
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxBraceMatcher"/>
    <lang.commenter
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxCommenter"/>
    <enterHandlerDelegate
        implementation="dev.jux.intellij.editor.JuxEnterHandler"/>
    <lineIndentProvider
        implementation="dev.jux.intellij.editor.JuxLineIndentProvider"/>

    <!-- Optimize Imports (Ctrl+Alt+O): drop unused / duplicate imports and sort
         the survivors, Java-style. The keybinding is the platform default. -->
    <lang.importOptimizer
        language="Jux"
        implementationClass="dev.jux.intellij.editor.JuxImportOptimizer"/>

    <!-- New Project / New Module support: the "Jux" generator scaffolds a
         jux.toml + src/main.jux project (§I — project model). -->
    <moduleType
        id="JUX_MODULE_TYPE"
        implementationClass="dev.jux.intellij.project.JuxModuleType"/>

    <!-- Run support: a "Jux" run-configuration type plus a context producer
         that autodetects `main` and enables the toolbar/right-click Run. -->
    <configurationType
        implementation="dev.jux.intellij.run.JuxRunConfigurationType"/>
    <runConfigurationProducer
        implementation="dev.jux.intellij.run.JuxRunConfigurationProducer"/>

    <!-- The "Jux" tool window (right side, like Gradle/Cargo): one-click
         Build / Run / Test / Build Release / Check over a live console. -->
    <toolWindow id="Jux"
                anchor="right"
                factoryClass="dev.jux.intellij.toolwindow.JuxToolWindowFactory"
                icon="dev.jux.intellij.JuxIcons.FILE"/>

    <!-- Persisted, IDE-wide Jux toolchain configuration (juxc / juxc-lsp / jux).
         Auto-detected from $JUX_HOME / PATH / install locations; configurable in
         Settings | Tools | Jux Toolchain. Every feature (LSP, Run, tool window)
         resolves through it. -->
    <applicationService serviceImplementation="dev.jux.intellij.settings.JuxSettings"/>
    <applicationConfigurable parentId="tools"
                             id="dev.jux.intellij.settings.JuxConfigurable"
                             instance="dev.jux.intellij.settings.JuxConfigurable"
                             displayName="Jux Toolchain"/>
  </extensions>

  <actions>
    <!-- A single "Jux File" entry under New, anchored before the generic
         "New File". Its dialog offers the class/interface/enum/record/
         annotation kinds, each with an icon — the Kotlin-plugin idiom. -->
    <action id="Jux.NewFile"
            class="dev.jux.intellij.actions.NewJuxFileAction"
            text="Jux File"
            description="Create a new Jux file">
      <add-to-group group-id="NewGroup" anchor="before" relative-to-action="NewFile"/>
    </action>
    <!-- New → Jux Package (nested directories from a dotted name). -->
    <action id="Jux.NewPackage"
            class="dev.jux.intellij.actions.NewJuxPackageAction"
            text="Jux Package"
            description="Create a new Jux package (nested directories)">
      <add-to-group group-id="NewGroup" anchor="after" relative-to-action="Jux.NewFile"/>
    </action>

    <!-- Alt+Insert "Generate" menu inside a Jux class: constructor + accessors
         built from the class's own fields. Each is only enabled inside a type
         body (see JuxGenerateAction.update). -->
    <action id="Jux.Generate.Constructor"
            class="dev.jux.intellij.actions.JuxGenerateConstructorAction"
            text="Constructor"
            description="Generate a constructor from the class's fields">
      <add-to-group group-id="Generate" anchor="first"/>
    </action>
    <action id="Jux.Generate.Getters"
            class="dev.jux.intellij.actions.JuxGenerateGettersAction"
            text="Getters"
            description="Generate a getter for each field">
      <add-to-group group-id="Generate" anchor="after" relative-to-action="Jux.Generate.Constructor"/>
    </action>
    <action id="Jux.Generate.Setters"
            class="dev.jux.intellij.actions.JuxGenerateSettersAction"
            text="Setters"
            description="Generate a setter for each field">
      <add-to-group group-id="Generate" anchor="after" relative-to-action="Jux.Generate.Getters"/>
    </action>
    <action id="Jux.Generate.OverrideMethods"
            class="dev.jux.intellij.actions.JuxOverrideMethodsAction"
            text="Override/Implement Methods"
            description="Generate @override stubs for inherited methods not yet declared">
      <add-to-group group-id="Generate" anchor="after" relative-to-action="Jux.Generate.Setters"/>
    </action>
  </actions>
</idea-plugin>
