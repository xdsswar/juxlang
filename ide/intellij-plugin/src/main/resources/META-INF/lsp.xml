<idea-plugin>
  <!-- Loaded only when `com.intellij.modules.lsp` is present (all commercial
       IDEs + unified IDEA free mode 2025.2+). On IDEs without it this file is
       ignored and the LSP classes never load — the plugin stays functional
       (file type, New actions, Run) and the LSP4IJ fallback (lsp4ij.xml)
       covers language-server features instead. -->

  <extensions defaultExtensionNs="com.intellij">
    <platform.lsp.serverSupportProvider
        implementation="dev.jux.intellij.lsp.JuxLspServerSupportProvider"/>
  </extensions>
</idea-plugin>
