<idea-plugin>
  <!-- Loaded only when `com.intellij.modules.ultimate` is present (the native
       LSP API ships in paid IDEs). On IDEs without it this file is ignored and
       the LSP classes never load, so the plugin stays functional there (file
       type, New actions, Run) without the LSP client. -->
  <extensions defaultExtensionNs="com.intellij">
    <platform.lsp.serverSupportProvider
        implementation="dev.jux.intellij.lsp.JuxLspServerSupportProvider"/>
  </extensions>
</idea-plugin>
