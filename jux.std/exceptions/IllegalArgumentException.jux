/**
 * jux.std.exceptions.IllegalArgumentException
 *
 * Argument value violated a method's precondition. Mirrors
 * `java.lang.IllegalArgumentException`.
 */
package jux.std.exceptions;

public class IllegalArgumentException extends RuntimeException {
    /**
     * Construct an IllegalArgumentException with a message
     * describing the precondition that was violated.
     */
    public IllegalArgumentException(String message) {
        super(message);
    }
}
