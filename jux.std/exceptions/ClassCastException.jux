/**
 * jux.std.exceptions.ClassCastException
 *
 * Runtime cast that the value's actual type doesn't satisfy
 * (e.g. `(Cat) animal` where `animal` is a `Dog`). Mirrors
 * `java.lang.ClassCastException`.
 */
package jux.std.exceptions;

public class ClassCastException extends RuntimeException {
    /**
     * Construct a ClassCastException with a message describing
     * the source and target types.
     */
    public ClassCastException(String message) {
        super(message);
    }
}
